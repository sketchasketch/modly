{
  "compilerOptions": {
    "target":            "ES2022",
    "module":            "CommonJS",
    "moduleResolution":  "node",
    "strict":            true,
    "skipLibCheck":      true,
    "outDir":            "out/builtin-extensions",
    "rootDir":           "builtin-extensions",
    "declaration":       false,
    "sourceMap":         false,
    "esModuleInterop":   true
  },
  "include": ["builtin-extensions/**/*.ts"]
}
